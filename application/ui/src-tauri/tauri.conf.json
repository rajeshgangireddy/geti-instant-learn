{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "geti_ui",
    "version": "0.1.0",
    "identifier": "com.intel",
    "build": {
        "frontendDist": "../dist-tauri",
        "devUrl": "http://localhost:3000",
        "beforeDevCommand": "npm run start:tauri",
        "beforeBuildCommand": "npm run build:tauri"
    },
    "app": {
        "windows": [
            {
                "title": "Geti Instant Learn",
                "width": 800,
                "height": 600,
                "resizable": true,
                "fullscreen": false,
                "additionalBrowserArgs": "--enable-unsafe-webgpu --enable-features=Vulkan"
            }
        ],
        "security": {
            "csp": null
        },
        "withGlobalTauri": true
    },
    "bundle": {
        "active": true,
        "targets": ["app"],
        "externalBin": ["instant-learn-backend"],
        "resources": ["_internal", "InitialData"],
        "icon": ["icons/icon.ico"]
    }
}
